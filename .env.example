# Sweet Sunday dashboard live-data setup
# Copy this file to .env and fill in the private values.
# Never paste these values into index.html or any browser/frontend file.

# Example: sweet-sunday.myshopify.com
SHOPIFY_SHOP_DOMAIN=

# Private Shopify Admin API access token. Keep this server-side only.
# Recommended custom app scopes for this Phase 2 store adapter:
# - read_orders
# - read_products
# - read_inventory
SHOPIFY_ADMIN_TOKEN=

# Optional
SHOPIFY_API_VERSION=2025-01
PORT=8766
